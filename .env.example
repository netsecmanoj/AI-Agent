APP_NAME=Internal Security Audit Platform
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
SECRET_KEY=change-this-in-production
SESSION_COOKIE_SECURE=false
SESSION_MAX_AGE_SECONDS=28800
BOOTSTRAP_ADMIN_USERNAME=
BOOTSTRAP_ADMIN_PASSWORD=
OIDC_ENABLED=false
OIDC_ISSUER_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_SCOPES=openid profile email
OIDC_ROLE_CLAIM=groups
OIDC_DEFAULT_ROLE=viewer
OIDC_ADMIN_GROUPS=
OIDC_REVIEWER_GROUPS=
OIDC_VIEWER_GROUPS=
OIDC_USERNAME_CLAIM=preferred_username
OIDC_EMAIL_CLAIM=email
OIDC_NAME_CLAIM=name
DATABASE_URL=sqlite:///./db/security_audit.db
ALLOW_LOCAL_PATH_SCANS=true
ALLOW_ARCHIVE_UPLOADS=true
SCAN_UPLOAD_DIR=uploads
SCAN_WORKSPACE_DIR=workspaces
REPORT_OUTPUT_DIR=reports/generated
# Scanner commands default to names on PATH.
# If a local host install lives elsewhere, set an absolute path in your real `.env`.
# Examples for local-only overrides might look like:
#   SEMGREP_COMMAND=/opt/homebrew/bin/semgrep
#   TRIVY_COMMAND=/opt/homebrew/bin/trivy
#   PIP_AUDIT_COMMAND=/path/to/project/.venv/bin/pip-audit
#   FLUTTER_COMMAND=/path/to/flutter/bin/flutter
#   DART_COMMAND=/path/to/flutter/bin/dart
SEMGREP_COMMAND=semgrep
SEMGREP_CONFIG=auto
SEMGREP_TIMEOUT_SECONDS=300
TRIVY_COMMAND=trivy
TRIVY_TIMEOUT_SECONDS=300
PIP_AUDIT_COMMAND=pip-audit
PIP_AUDIT_TIMEOUT_SECONDS=300
NPM_COMMAND=npm
NPM_AUDIT_TIMEOUT_SECONDS=300
FLUTTER_COMMAND=flutter
DART_COMMAND=dart
DART_ANALYZE_TIMEOUT_SECONDS=300
DART_PUB_OUTDATED_TIMEOUT_SECONDS=300
JOB_POLL_INTERVAL_SECONDS=1
# AI is optional. Leave disabled for deterministic-only scanning.
# To enable a local Ollama or other OpenAI-compatible endpoint:
#   AI_ENABLED=true
#   AI_PROVIDER=ollama
#   AI_MODEL=llama3.1:8b
#   AI_BASE_URL=http://127.0.0.1:11434/v1
# For a hosted OpenAI-compatible endpoint:
#   AI_ENABLED=true
#   AI_PROVIDER=openai_compatible
#   AI_MODEL=gpt-4o-mini
#   AI_BASE_URL=https://your-gateway.example.com/v1
#   AI_API_KEY=replace-me
AI_ENABLED=false
AI_PROVIDER=disabled
AI_MODEL=llama3.1:8b
AI_BASE_URL=http://127.0.0.1:11434/v1
AI_API_KEY=
AI_TIMEOUT_SECONDS=30
API_TOKENS=
ALLOW_API_LOCAL_PATH_SCANS=false
WEBHOOK_SHARED_SECRET=
CI_DEFAULT_FAIL_SEVERITY=
POLICY_FAIL_ON_NEW_CRITICAL=true
POLICY_MAX_NEW_HIGH_FINDINGS=0
POLICY_MAX_WEIGHTED_RISK_DELTA=5
POLICY_WARN_ON_ANY_HIGH_FINDINGS=true
POLICY_WARN_ON_PARTIAL_SCAN=true
UPLOAD_RETENTION_DAYS=30
WORKSPACE_RETENTION_DAYS=30
REPORT_RETENTION_DAYS=30
CLEANUP_INTERVAL_SECONDS=3600
CLEANUP_ON_STARTUP=true
