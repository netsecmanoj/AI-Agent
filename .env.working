WEBHOOK_SHARED_SECRET=
CI_DEFAULT_FAIL_SEVERITY=
POLICY_FAIL_ON_NEW_CRITICAL=true
POLICY_MAX_NEW_HIGH_FINDINGS=0
POLICY_MAX_WEIGHTED_RISK_DELTA=5
POLICY_WARN_ON_ANY_HIGH_FINDINGS=true
POLICY_WARN_ON_PARTIAL_SCAN=true
UPLOAD_RETENTION_DAYS=30
WORKSPACE_RETENTION_DAYS=30
REPORT_RETENTION_DAYS=30
